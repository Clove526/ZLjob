# 后端环境变量
PORT=3001

# LLM 配置（DeepSeek / OpenAI 兼容）
# 使用 DeepSeek：LLM_BASE_URL=https://api.deepseek.com  LLM_MODEL=deepseek-chat
# 使用 OpenAI：LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Supabase 配置（可选，不配置则使用内置数据）
SUPABASE_URL=
SUPABASE_SERVICE_KEY=