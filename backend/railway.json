{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "commands": ["npm install"]
        },
        "setup": {
          "commands": ["npm install"]
        },
        "build": {
          "commands": []
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node src/index.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}